GITEA_URL=https://gitea.example.com
GITEA_TOKEN=
POCKET_ID_URL=https://pocket-id.example.com
POCKET_ID_TOKEN=
POCKET_ID_HEALTH_PATH=/api/health
N8N_URL=https://n8n.example.com
N8N_API_KEY=
N8N_API_PATH=/api/v1
MCP_TRANSPORT=stdio
# Used for http or sse transports.
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Required when MCP_TRANSPORT is http, sse, or streamable-http.
MCP_AUTH_MODE=none

# Use oidc_proxy when clients should be sent through Pocket ID login on first connect.
MCP_AUTH_BASE_URL=https://labmcp.example.com
MCP_AUTH_OIDC_CONFIG_URL=
MCP_AUTH_OIDC_CLIENT_ID=
MCP_AUTH_OIDC_CLIENT_SECRET=
MCP_AUTH_OIDC_REDIRECT_PATH=/auth/callback
# Extra scopes requested from the upstream IdP. offline_access enables refresh tokens.
MCP_AUTH_OIDC_EXTRA_SCOPES=offline_access
MCP_AUTH_OIDC_JWT_SIGNING_KEY=
# Pocket ID does not accept the OAuth resource indicator; leave this false.
MCP_AUTH_OIDC_FORWARD_RESOURCE=false
# Request groups from Pocket ID to use service authorization.
MCP_AUTH_REQUIRED_SCOPES=openid,profile,groups
# Claim holding a user's groups or roles. Pocket ID uses groups by default.
MCP_AUTH_GROUP_CLAIM=groups
# JSON mapping: service keys (gitea, pocket_id, n8n) to Pocket ID OIDC group/role names.
# A mapped service requires membership of any listed Pocket ID group or role.
# MCP_SERVICE_GROUPS={"gitea":["mcp-gitea"],"pocket_id":["mcp-pocket-id"]}
MCP_SERVICE_GROUPS={}

# Use jwt when clients already have a Pocket ID JWT and only need token verification.
# For Pocket ID, issuer defaults to POCKET_ID_URL.
# JWKS defaults to <issuer>/.well-known/jwks.json.
MCP_AUTH_JWT_ISSUER=
MCP_AUTH_JWT_JWKS_URI=
MCP_AUTH_JWT_AUDIENCE=
