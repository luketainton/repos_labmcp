GITEA_URL=https://gitea.example.com
GITEA_TOKEN=
POCKET_ID_URL=https://pocket-id.example.com
POCKET_ID_TOKEN=
POCKET_ID_HEALTH_PATH=/api/health
MCP_TRANSPORT=stdio
# Used for http or sse transports.
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Required when MCP_TRANSPORT is http, sse, or streamable-http.
MCP_AUTH_MODE=none

# Use oidc_proxy when clients should be sent through Pocket ID login on first connect.
MCP_AUTH_BASE_URL=https://labmcp.example.com
MCP_AUTH_OIDC_CONFIG_URL=
MCP_AUTH_OIDC_CLIENT_ID=
MCP_AUTH_OIDC_CLIENT_SECRET=
MCP_AUTH_OIDC_REDIRECT_PATH=/auth/callback
MCP_AUTH_OIDC_JWT_SIGNING_KEY=
MCP_AUTH_REQUIRED_SCOPES=

# Use jwt when clients already have a Pocket ID JWT and only need token verification.
# For Pocket ID, issuer defaults to POCKET_ID_URL.
# JWKS defaults to <issuer>/.well-known/jwks.json.
MCP_AUTH_JWT_ISSUER=
MCP_AUTH_JWT_JWKS_URI=
MCP_AUTH_JWT_AUDIENCE=
